<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.VoiceX" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_cyan</item>
        <item name="colorPrimaryVariant">@color/bg_dark</item>
        <item name="colorOnPrimary">@color/bg_dark</item>
        <item name="colorSecondary">@color/accent_pink</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:colorBackground">@color/bg_dark</item>
        <item name="colorSurface">@color/bg_panel</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="Theme.VoiceX.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/bg_dark</item>
        <item name="postSplashScreenTheme">@style/Theme.VoiceX</item>
    </style>
</resources>
