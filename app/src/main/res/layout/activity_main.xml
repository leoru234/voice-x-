<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="VOICE"
                android:textSize="24sp"
                android:fontFamily="monospace"
                android:textColor="@color/accent_cyan" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● READY"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:textColor="@color/text_dim"
                android:background="@drawable/bg_status_badge"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_panel"
            android:orientation="horizontal"
            android:padding="4dp"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btnCallMode"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="CALL MODE"
                android:textSize="12sp"
                android:background="@drawable/selector_mode_btn"
                android:selected="true" />

            <Button
                android:id="@+id/btnGameMode"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="GAME MODE"
                android:textSize="12sp"
                android:background="@drawable/selector_mode_btn" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_panel"
            android:orientation="vertical"
            android:padding="12dp"
            android:layout_marginBottom="12dp">

            <com.voicex.app.utils.WaveformView
                android:id="@+id/waveformView"
                android:layout_width="match_parent"
                android:layout_height="80dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="INPUT"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:textColor="@color/text_dim"
                    android:minWidth="60dp" />

                <ProgressBar
                    android:id="@+id/levelBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_height="6dp"
                    android:layout_weight="1"
                    android:progressDrawable="@drawable/level_bar_drawable"
                    android:max="100"
                    android:progress="0" />

                <TextView
                    android:id="@+id/tvLevelVal"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:text="-60 dB"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:textColor="@color/accent_cyan"
                    android:gravity="end" />
            </LinearLayout>
        </LinearLayout><LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btnMic"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:text="MIC"
                android:textSize="32sp"
                android:background="@drawable/selector_mic_btn" />

            <TextView
                android:id="@+id/tvMicLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TAP TO START"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:textColor="@color/text_dim"
                android:layout_marginTop="10dp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="// VOICE PRESETS"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:textColor="@color/text_dim"
            android:layout_marginBottom="8dp" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="4"
            android:rowCount="2"
            android:layout_marginBottom="16dp"
            android:useDefaultMargins="true">

            <include layout="@layout/item_preset" android:id="@+id/presetNormal" />
            <include layout="@layout/item_preset" android:id="@+id/presetRobot" />
            <include layout="@layout/item_preset" android:id="@+id/presetDeep" />
            <include layout="@layout/item_preset" android:id="@+id/presetChipmunk" />
            <include layout="@layout/item_preset" android:id="@+id/presetAlien" />
            <include layout="@layout/item_preset" android:id="@+id/presetGhost" />
            <include layout="@layout/item_preset" android:id="@+id/presetFemale" />
            <include layout="@layout/item_preset" android:id="@+id/presetRadio" />
        </GridLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="// MANUAL CONTROLS"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:textColor="@color/text_dim"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_panel"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <include layout="@layout/item_slider" android:id="@+id/rowPitch" />
            <include layout="@layout/item_slider" android:id="@+id/rowVolume" />
            <include layout="@layout/item_slider" android:id="@+id/rowReverb" />
            <include layout="@layout/item_slider" android:id="@+id/rowEcho" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="// EFFECTS"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:textColor="@color/text_dim"
            android:layout_marginBottom="8dp" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:useDefaultMargins="true"
            android:layout_marginBottom="16dp">

            <include layout="@layout/item_effect_toggle" android:id="@+id/toggleNoise" />
            <include layout="@layout/item_effect_toggle" android:id="@+id/toggleBass" />
            <include layout="@layout/item_effect_toggle" android:id="@+id/toggleWhisper" />
            <include layout="@layout/item_effect_toggle" android:id="@+id/toggleRobot" />
        </GridLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_panel"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="10dp"
                android:layout_marginEnd="4dp">
                <TextView android:id="@+id/tvLatStat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textSize="18sp"
                    android:fontFamily="monospace"
                    android:textColor="@color/accent_cyan" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LATENCY"
                    android:textSize="9sp"
                    android:fontFamily="monospace"
                    android:textColor="@color/text_dim" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_panel"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="10dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp">
                <TextView android:id="@+id/tvCpuStat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textSize="18sp"
                    android:fontFamily="monospace"
                    android:textColor="@color/accent_cyan" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CPU USE"
                    android:textSize="9sp"
                    android:fontFamily="monospace"
                    android:textColor="@color/text_dim" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_panel"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="10dp"
                android:layout_marginStart="4dp">
                <TextView android:id="@+id/tvSessionTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textSize="18sp"
                    android:fontFamily="monospace"
                    android:textColor="@color/accent_cyan" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SESSION"
                    android:textSize="9sp"
                    android:fontFamily="monospace"
                    android:textColor="@color/text_dim" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_panel"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="10dp"
            android:layout_marginBottom="16dp">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/dot_green" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="  LOW LATENCY MODE ACTIVE"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:textColor="@color/text_dim" />

            <TextView
                android:id="@+id/tvLatency"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4ms"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:textColor="@color/accent_green" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
